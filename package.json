{
  "name": "minimart-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node static-server.js",
    "build": "node replace-env.js && ng build --configuration production",
    "start:dev": "ng serve --proxy-config proxy.conf.json",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "compile:server": "webpack --config webpack.server.config.js --progress --colors",
    "serve:ssr": "node dist/server",
    "build:ssr": "npm run build:client-and-server-bundles && npm run compile:server",
    "build:client-and-server-bundles": "ng build --prod && ng run minimart-web:server:production"
  },
  "private": true,
